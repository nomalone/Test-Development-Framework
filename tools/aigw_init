    def write_smoke_route_to_txt(self):
        """创建后API-CHECK后，写入API-CHECK的ID到smoke_route.txt文件"""
        global api_check_id, api_route_id
        url = f"***"
        params = {}
        r = requests.get(url, headers=self.headers, params=params, verify=False)
        v1_list = r.json()['data']['list']
        for i in v1_list:
            if "auto_v1_check" == i["name"]:
                api_route_id = i["route_id"]
                api_check_id = i["_id"]
                with open("smoke_route.txt", "w") as f:
                    f.write(api_route_id[4:])
                break

    def del_v1_check(self):
        """删除v1_check"""
        url = f"**"
        params = {
            "page": 1,
            "pageSize": 1000
        }
        r = requests.get(url, headers=self.headers, params=params, verify=False)
        v1_list = r.json()['data']['list']
        for i in v1_list:
            if "auto_v1_check" == i["name"]:
                id = i["_id"]
                del_url = f"{self.url}/api/apiKey/{id}"
                requests.delete(del_url, headers=self.headers, verify=False)
                break

    def del_all(self):
        # 删除系统中可能存在的消费者、组织架构、路由、域名、模型
        self.del_v1_check()

        for i in consumer_info:
            self.del_consumer(i[0])

        self.del_department()

        for i in route_info:
            for j in i:
                self.del_route(j[1])
                self.del_domain(j[0])

        for i in provider_info:
            for j in i:
                self.del_provider(j["name"])

    def create_all(self):
        # 创建模型
        provider_mock_id = self.create_provider(provider_info[0][0])
        provider_auto_id = self.create_provider(provider_info[1][0])

        # 创建路由
        for i in route_info[0]:
            self.create_route(provider_mock_id, i[0], i[1])
        for i in route_info[1]:
            self.create_route(provider_auto_id, i[0], i[1])
        self.create_api_check_route(provider_auto_id, InitConfig().ROUTE_API_CHECK_INFO[0])

        # 创建组织架构、消费者
        department_id = self.create_department()
        self.create_consumer(consumer_info[0][1], consumer_info[0][0], department_id, route_info)

        # 创建v1_check
        self.create_v1_check()

        # 写入冒烟路由ID到txt文件
        self.write_smoke_route_to_txt()
        # 初始化api_check插件配置
        SetGuard().set_api_check()


class SetGuard:
    """增强管理所有插件保存，生成对应的路由，并关闭所有插件"""
    def __init__(self):
        self.url = InitConfig().URL
        self.cookie = InitAIGW().login()
        self.headers = {'Cookie': self.cookie}

    def set_guard(self, pluginName, configurations, route_id, enabled = True):
        data = {}
        url = f"***"
        try:
            r = requests.put(url, headers=self.headers, json=data, verify=False)
            r.raise_for_status()
        except Exception as e:
            raise Exception("插件配置发生错误: %s" % e)

    def set_api_check(self):
        data = {}
        url = f"***"
        try:
            r = requests.put(url, headers=self.headers, json=data, verify=False)
            r.raise_for_status()
        except Exception as e:
            raise Exception("插件配置发生错误: %s" % e)

    def save_set(self):
        for i in route_info:
            for j in i:
                route_id = j[1]
                guard_list = InitConfig().GUARD
                guard_conf = InitConfig().GUARD_CONF
                for index, values in enumerate(guard_list):
                    if values == "ks-waf":
                        self.set_guard(values, guard_conf[index], route_id, False)
                    else:
                        self.set_guard(values, guard_conf[index], route_id)



if __name__ == '__main__':
    init = InitAIGW()
    # 无参数时默认执行 create_all
    if len(sys.argv) == 1:
        method_name = "create_all"
        method_args = []
    else:
        method_name = sys.argv[1]
        method_args = sys.argv[2:]  # 收集方法参数

    # 区分无参数方法和有参数方法
    no_arg_methods = {"create_all", "del_all"}  # 定义无参数方法集合
    method = getattr(init, method_name)

    try:
        if method_name in no_arg_methods:
            # 无参数方法不允许传参
            if len(method_args) > 0:
                raise TypeError(f"方法 {method_name} 不接受参数，却传入了：{method_args}")
            method()
        else:
            # 有参数方法必须传参
            if len(method_args) == 0:
                raise TypeError(f"方法 {method_name} 需要传入参数，请补充参数")
            method(*method_args)
    except TypeError as e:
        print(f"参数错误：{e}")
        sys.exit(1)

    if method_name == "create_all":
        guard = SetGuard()
        guard.save_set()

    print(f"{method_name} 完成")

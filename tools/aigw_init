class InitAIGW:

    def __init__(self):
        self.url = InitConfig().URL
        self.cookie = self.login()
        self.headers = {'Cookie': self.cookie}

    def login(self):
        """
        登录接口，获取登录token
        """
        data = InitConfig().LOGIN_REQ
        url = f"***"
        try:
            r = requests.post(url, json=data, verify=False)
            r.raise_for_status()  # 检查请求是否成功
            cookies = r.headers.get("set-cookie").split("path=/;")
            cookie = ""
            for i in cookies[:4]:
                if 'secure; httponly,' in i:
                    x = i.split('secure; httponly,')[1]
                    cookie += x
                else:
                    cookie += i
            return cookie
        except Exception as e:
            raise Exception("登录失败，无法初始化请求: %s" % e)

    def create_provider(self, req):
        """
        创建模型：
        """
        url = f"***"
        try:
            search_r = requests.get(url, headers=self.headers, verify=False)
            if req["name"] in str(search_r.json()):
                return req["name"]
            r = requests.post(url, headers=self.headers, json=req, verify=False)
            r.raise_for_status()
            provider_id = r.json()["rawConfigs"]["id"]
            return provider_id
        except Exception as e:
            raise Exception("创建模型发生错误: %s" % e)

